# Supabase configuration (optional - app runs locally without these)
# Copy this to .env.local and fill in your project values
#
# 1. Create a free project at https://supabase.com
# 2. Run the SQL schema from docs/supabase-schema.sql in the Supabase SQL editor
# 3. Enable Realtime for 'weigh_ins' and 'teams' tables in the dashboard
# 4. Copy the values from: Project Settings → API

VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Stripe configuration (optional - required for subscription billing only)
# Phase 5: Subscription tiers (Free / Pro $9.99/mo / Org $29.99/mo)
#
# Setup steps:
# 1. Create a Stripe account at https://stripe.com
# 2. Create recurring prices for Pro and Org plans in Stripe Dashboard → Products
# 3. Copy the price IDs (format: price_...) below
# 4. Deploy Edge Functions: supabase functions deploy create-checkout-session
#                           supabase functions deploy create-portal-session
#                           supabase functions deploy stripe-webhook
# 5. Set Edge Function secrets (never put these in .env.local):
#      supabase secrets set STRIPE_SECRET_KEY=sk_live_...
#      supabase secrets set STRIPE_WEBHOOK_SECRET=whsec_...
#      supabase secrets set STRIPE_PRO_PRICE_ID=price_...
#      supabase secrets set STRIPE_ORG_PRICE_ID=price_...
# 6. Register webhook in Stripe Dashboard → Webhooks:
#      URL: https://<project-ref>.supabase.co/functions/v1/stripe-webhook
#      Events: checkout.session.completed, customer.subscription.updated,
#              customer.subscription.deleted, invoice.payment_failed
# 7. Enable Billing Portal in Stripe Dashboard → Settings → Billing Portal

VITE_STRIPE_PUBLISHABLE_KEY=pk_live_...   # for future embedded checkout
VITE_STRIPE_PRO_PRICE_ID=price_...        # passed to create-checkout-session
VITE_STRIPE_ORG_PRICE_ID=price_...        # passed to create-checkout-session

# Edge Function secrets — set via: supabase secrets set KEY=value
# NEVER put these in .env.local — they are server-side only
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_WEBHOOK_SECRET=whsec_...
